# Supabase Configuration
# Copy this file to .env.local and fill in your values

# Your Supabase project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Medical Evidence API URL
NEXT_PUBLIC_MEDICAL_API_URL=http://localhost:3050

# EVE Control Chain — ENERGY demo (server-side only, never NEXT_PUBLIC)
# Local dev: point straight at a locally running eve-ctrl-poc (no key needed)
#   CTRL_ENERGY_BASE=http://127.0.0.1:3210
# Vercel/prod: nginx gate on the VPS + secret header
#   CTRL_ENERGY_BASE=https://api.eveverified.com/ctrl-energy
#   CTRL_ENERGY_KEY=<nginx gate secret>
CTRL_ENERGY_BASE=http://127.0.0.1:3210
CTRL_ENERGY_KEY=
